# inode — environment configuration
# Copy to .env for local development. Never commit .env.
#
# All variables can also be set in ~/.inode/config.toml.
# Environment variables take precedence over the config file.

# ── LLM ────────────────────────────────────────────────────────
INODE_LLM_BACKEND=claude-api               # claude-api | ollama (Phase 3)
INODE_LLM_MODEL=claude-sonnet-4-6
INODE_LLM_API_KEY=sk-ant-your-key-here

# ── Embeddings ─────────────────────────────────────────────────
INODE_EMBEDDING_BACKEND=voyage             # voyage | local (Phase 3)
INODE_EMBEDDING_MODEL=voyage-3
INODE_EMBEDDING_API_KEY=pa-your-key-here

# ── Database ───────────────────────────────────────────────────
INODE_DB_PATH=~/.inode/notes.db            # SQLite path (Phase 1)

# ── Defaults ───────────────────────────────────────────────────
INODE_DEFAULT_SENSITIVE=true               # new notes are sensitive by default

# ── Development ────────────────────────────────────────────────
INODE_LOG_LEVEL=debug                      # debug | info | warn | error
